# Copy this file to .env and fill in real values before running the server.
# `.env` is git-ignored — never commit real secrets.

PORT=3000

# Long random string used to sign admin login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Admin PIN used the very first time the server starts (only takes effect if
# no PIN has been set yet). Change it from the admin panel after logging in —
# it's stored bcrypt-hashed in the database from that point on, never in
# plaintext or in this file.
ADMIN_PIN=1558

# PayPal REST API credentials — from developer.paypal.com → Apps & Credentials.
# Use your Sandbox app's credentials while testing, Live app's credentials in production.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# Restrict which origins may call the API in production, e.g. https://yourdomain.com
# Leave unset locally to allow all origins.
# CORS_ORIGIN=https://yourdomain.com
